# Kosha provider configuration.
# Copy this file to .env, uncomment the variables you need, fill in local values,
# then load it with:
#   source .env
#   uv run kosha doctor providers
#
# Do not commit real API keys. .env is ignored by git.

# Embedding provider ---------------------------------------------------------
# Leave KOSHA_EMBED_BASE_URL unset to use the deterministic local default
# (lexical-hash-256). Set it to an OpenAI-compatible /v1 API base URL to use
# a real embedding provider. Do not append /embeddings.
# export KOSHA_EMBED_BASE_URL=https://api.openai.com/v1
# export KOSHA_EMBED_MODEL=text-embedding-3-small
# export KOSHA_EMBED_API_KEY=sk-REPLACE_ME
# Must match the vector dimension returned by the embedding endpoint.
# Kosha defaults to 1536 when this is unset.
# export KOSHA_EMBED_DIM=1536

# Generation provider --------------------------------------------------------
# Leave KOSHA_GEN_BASE_URL unset to use the deterministic local default
# (extractive-3). Set it to an OpenAI-compatible /v1 API base URL to use a real
# generation provider. Do not append /chat/completions.
# export KOSHA_GEN_BASE_URL=https://api.openai.com/v1
# export KOSHA_GEN_MODEL=gpt-4o-mini
# export KOSHA_GEN_API_KEY=sk-REPLACE_ME

# OpenRouter cheap generation example ---------------------------------------
# OpenRouter exposes an OpenAI-compatible chat-completions API at /api/v1.
# Keep embeddings local unless you also configure KOSHA_EMBED_* above.
# The model below is a low-cost generation model from the OpenRouter catalog.
# export OPENROUTER_API_KEY=sk-or-REPLACE_ME
# export KOSHA_GEN_BASE_URL=https://openrouter.ai/api/v1
# export KOSHA_GEN_MODEL=google/gemini-2.5-flash-lite
# export KOSHA_GEN_API_KEY=${OPENROUTER_API_KEY:?Set OPENROUTER_API_KEY before sourcing .env}

# Example: local Ollama-compatible endpoint ---------------------------------
# export KOSHA_EMBED_BASE_URL=http://localhost:11434/v1
# export KOSHA_EMBED_MODEL=nomic-embed-text
# export KOSHA_EMBED_API_KEY=
# export KOSHA_EMBED_DIM=768
# export KOSHA_GEN_BASE_URL=http://localhost:11434/v1
# export KOSHA_GEN_MODEL=llama3.1
# export KOSHA_GEN_API_KEY=
